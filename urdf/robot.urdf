<robot name="my_simulation_robot">
    <!-- creating the root link -->
    <link name="world"/>

    <!-- adding a fixed joint to attach base of the robot to the world -->
    <joint name="world_to_base" type="fixed">
        <parent link="world"/> <!-- parent link is the world-->
        <child link="base_link"/> <!-- child link is the base of the robot-->
    </joint>

    <!-- creating the robot base Link -->
    <link name="base_link">
        <visual> <!--the base of the robot will be a box with the given values-->
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>

            <material name="lime">
                <color rgba="0 1 0 1"/> <!-- Bright white -->
            </material>


        </visual>
        <collision>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/> <!--mass of the base-->
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
    </link>

    <!-- adding the robot's left wheel -->
    <link name="robot_left_wheel">
        <visual>
            <geometry>
                <cylinder length="0.05" radius="0.1"/> <!--cyclinder with mentioned length-->
            </geometry>

            <material name="black">
                <color rgba="0 0 0 1"/> <!-- Deep black -->
            </material>

        </visual>
        <collision>
            <geometry>
                <cylinder length="0.05" radius="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="robot_left_wheel_joint" type="continuous"> <!--continous joint that connects the left wheel to the base-->
        <parent link="base_link"/>
        <child link="robot_left_wheel"/>
        <origin xyz="-0.25 0.3 0" rpy="0 1.5708 0"/> <!--orientation and position of the left wheel relative to the base of the robot-->
        <axis xyz="0 1 0"/> <!--rotation is akong the y-axis-->
    </joint>

    <!-- adding the robot's right wheel -->
    <link name="robot_right_wheel">
        <visual>
            <geometry>
                <cylinder length="0.05" radius="0.1"/>
            </geometry>

            <material name="black">
                <color rgba="0 0 0 1"/> <!-- Deep black -->

            </material>

        </visual>
        <collision>
            <geometry>
                <cylinder length="0.05" radius="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="robot_right_wheel_joint" type="continuous"> <!--continous joint that connects the right wheel to the base-->
        <parent link="base_link"/>
        <child link="robot_right_wheel"/>
        <origin xyz="-0.25 -0.3 0" rpy="0 1.5708 0"/>  <!--orientation and position of the right wheel relative to the base of the robot-->
        <axis xyz="0 1 0"/> <!--rotation is along the y-axis-->
    </joint>
</robot>
