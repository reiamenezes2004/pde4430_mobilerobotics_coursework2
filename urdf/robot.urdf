<robot name="my_simulation_robot">
    <link name="world"/>

        <joint name="world_to_base" type="fixed">
            <parent link="world"/>
            <child link="base_link"/>
        </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>

        </visual>
        <collision>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
    </link>
</robot>
