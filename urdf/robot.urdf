<robot name="my_simulation_robot">
    <link name="world"/>

        <joint name="world_to_base" type="fixed">
            <parent link="world"/>
            <child link="base_link"/>
        </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
            <material name="black">
                <color rgba="0 0 0 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
    </link>

    <link name="wheel_left">
    <visual>
        <geometry>
            <cylinder length="0.05" radius="0.1"/>
        </geometry>
         <material name="white">
                <color rgba="1 1 1 1"/>
        </material>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.05" radius="0.1"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
</link>

<joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="-0.25 0.3 0" rpy="0 1.5708 0"/>
    <axis xyz="0 1 0"/>
</joint>

<link name="wheel_right">
    <visual>
        <geometry>
            <cylinder length="0.05" radius="0.1"/>
        </geometry>
         <material name="white">
                <color rgba="1 1 1 1"/>
        </material>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.05" radius="0.1"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
</link>

<joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="-0.25 -0.3 0" rpy="0 1.5708 0"/>
    <axis xyz="0 1 0"/>
</joint>

</robot>
